{
  "displayName": "Darwin VM — disk usage > 90% (critical)",
  "documentation": {
    "content": "Persistent disk on darwin-vm is over 90% full. Immediate cleanup or resize required.",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "Ops Agent disk percent_used > 90",
      "conditionThreshold": {
        "filter": "resource.type = \"gce_instance\" AND resource.labels.instance_id = \"REPLACE_INSTANCE_ID\" AND metric.type = \"agent.googleapis.com/disk/percent_used\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 90,
        "duration": "180s",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_MEAN",
            "crossSeriesReducer": "REDUCE_MAX",
            "groupByFields": []
          }
        ]
      }
    }
  ],
  "notificationChannels": [
    "REPLACE_NOTIFICATION_CHANNEL"
  ],
  "alertStrategy": {
    "autoClose": "86400s"
  }
}
