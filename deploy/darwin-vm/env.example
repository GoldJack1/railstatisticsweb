# Darwin daemon runtime env
# Copy to: /etc/darwin-daemon.env

# Core daemon
DAEMON_PORT=4001
CORS_ORIGIN=https://railstatistics.co.uk
DEFAULT_WINDOW_HOURS=3
INITIAL_REPLAY_MIN=360
HEARTBEAT_SEC=60
PERSIST_INTERVAL_SEC=120
# Keep persisted Darwin/PTAC cache across day boundaries (recommended true)
KEEP_STATE_ACROSS_DAYS=true
# Avoid overwriting a richer cache with a degraded one after bad restarts
PROTECT_RICHER_STATE=true
# Keep rolling state snapshots in darwin-local-test/state/
STATE_SNAPSHOT_COUNT=24

# Timetable auto-fetch
DARWIN_AUTO_FETCH_FILES=true
DARWIN_AUTO_FETCH_TIME=04:05
DARWIN_STATIONS_REF_XML=/opt/railstats/darwin-local-test/StationsRefData_v1.2.xml
DARWIN_TIMETABLE_DIR=/opt/railstats/darwin-local-test/tt
DARWIN_GCS_PPT_PREFIX=gs://rail-statistics.firebasestorage.app/DARWINTTFILES/PPTimetable

# Darwin Push Port Kafka
DARWIN_BOOTSTRAP=
DARWIN_TOPIC=
DARWIN_GROUP_ID=
DARWIN_USERNAME=
DARWIN_PASSWORD=

# PTAC Kafka
PTAC_BOOTSTRAP=
PTAC_TOPIC=prod-1033-Passenger-Train-Allocation-and-Consist-1_0
PTAC_GROUP_ID=
PTAC_USERNAME=
PTAC_PASSWORD=

# Optional node tuning
# NODE_OPTIONS=--max-old-space-size=768
