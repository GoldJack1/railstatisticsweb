# Darwin daemon runtime env
# Copy to: /etc/darwin-daemon.env

# Core daemon
DAEMON_PORT=4001
# When to allow website/API clients (non-/api/health): restored = after formations/PTAC disk restore; warm = after historical warmup too (less load during warmup).
# DARWIN_CLIENT_READY_AFTER=restored
CORS_ORIGIN=https://railstatistics.co.uk
DEFAULT_WINDOW_HOURS=3
# Live departures board snapshot cache (browser polling).
DEPARTURES_CACHE_MS=3000
# Historical ?date=&at= responses — keep longer (expensive to rebuild).
DEPARTURES_HIST_CACHE_MS=120000
# Darwin Push Port Kafka replay on startup (minutes). 720 = 12h — stronger recovery after restarts than 360.
INITIAL_REPLAY_MIN=720
HEARTBEAT_SEC=60
PERSIST_INTERVAL_SEC=120
# Keep persisted Darwin/PTAC cache across day boundaries (recommended true)
KEEP_STATE_ACROSS_DAYS=true
# Avoid overwriting a richer cache with a degraded one after bad restarts
PROTECT_RICHER_STATE=true
# Keep rolling state snapshots in darwin-local-test/state/
STATE_SNAPSHOT_COUNT=24
# Keep timestamped history snapshots compressed (.json.gz) to reduce disk.
STATE_HISTORY_COMPRESS_SNAPSHOTS=true
# gzip level for compressed history snapshots (1=fastest, 9=smallest)
STATE_HISTORY_GZIP_LEVEL=6
# Optional: gzip level for formation/consist/unit/**overlay** shards (defaults to STATE_HISTORY_GZIP_LEVEL).
# Live Darwin overlays live in daemon-cache-heavy*.overlay.json.gz so core JSON stays small.
# STATE_HEAVY_GZIP_LEVEL=6
# Local hot-tier retention for state/history/<date>/. Beyond this, the daemon
# prunes day folders on persist (see STATE_HISTORY_PRUNE_ON_PERSIST).
STATE_HISTORY_RETENTION_DAYS=7
STATE_HISTORY_PRUNE_ON_PERSIST=true
# Historical read-path caches (speed up date/time browsing in UI)
# Timetable XML re-parse is expensive (~20–30s); keep hot for 24h on the VM.
HIST_TIMETABLE_CACHE_TTL_MS=86400000
HIST_TIMETABLE_CACHE_MAX=14
HIST_CONTEXT_CACHE_TTL_MS=1800000
HIST_CONTEXT_CACHE_MAX=48
HIST_STATE_FILE_CACHE_TTL_MS=3600000
HIST_STATE_FILE_CACHE_MAX=32
HIST_SNAPSHOT_LIST_CACHE_TTL_MS=60000

# Background day-by-day historical warmup. Runs after the API is "live_ready"
# and primes timetable/snapshot/context caches for the most recent N days
# from state/history/<date>/. Skips a date if RSS or event-loop lag breach
# the configured ceilings.
WARMUP_ENABLED=true
WARMUP_DAYS=7
WARMUP_MAX_RSS_MB=4500
WARMUP_LAG_MS=200

# Timetable auto-fetch
DARWIN_AUTO_FETCH_FILES=true
DARWIN_AUTO_FETCH_TIME=04:05
DARWIN_STATIONS_REF_XML=/opt/railstats/darwin-local-test/StationsRefData_v1.2.xml
DARWIN_TIMETABLE_DIR=/opt/railstats/darwin-local-test/tt
# Optional: disable gzipped JSON sidecars (*.jidx.json.gz) beside each .xml.gz
# TIMETABLE_JIDX_DISABLE=false
# Optional: gzip level for jidx writes (1–9, default 6)
# TIMETABLE_JIDX_GZIP_LEVEL=6
DARWIN_GCS_PPT_PREFIX=gs://rail-statistics.firebasestorage.app/DARWINTTFILES/PPTimetable

# Raw message archive (Darwin/PTAC feed)
RAW_ARCHIVE_ENABLED=true
# Store hourly archive files as gzip-compressed NDJSON to reduce disk usage.
RAW_ARCHIVE_COMPRESS=true
RAW_ARCHIVE_DIR=/opt/railstats/darwin-local-test/state/raw-feed
RAW_ARCHIVE_RETENTION_DAYS=7

# Darwin Push Port Kafka
DARWIN_BOOTSTRAP=
DARWIN_TOPIC=
DARWIN_GROUP_ID=
DARWIN_USERNAME=
DARWIN_PASSWORD=

# Optional: reduce noisy Confluent TLS handshake failures when Darwin + PTAC connect at once (defaults are fine if logs recover within seconds).
# KAFKA_CONNECTION_TIMEOUT_MS=30000
# KAFKA_AUTH_TIMEOUT_MS=30000
# KAFKA_REQUEST_TIMEOUT_MS=30000
# KAFKA_RETRY_COUNT=12
# PTAC_CONNECT_DELAY_MS=2500

# PTAC Kafka
PTAC_BOOTSTRAP=
PTAC_TOPIC=prod-1033-Passenger-Train-Allocation-and-Consist-1_0
# PTAC Kafka replay when PTAC_REPLAY_ANCHOR=rolling (minutes). 1440 = 24h — covers overnight PTAC after outages.
PTAC_INITIAL_REPLAY_MIN=1440
# Backfill after PTAC/daemon errors: replay from 00:01 London on today's timetable SSD, then remove on next deploy:
# PTAC_REPLAY_ANCHOR=ssd_0001
PTAC_GROUP_ID=
PTAC_USERNAME=
PTAC_PASSWORD=

# Optional node tuning
# NODE_OPTIONS=--max-old-space-size=768
