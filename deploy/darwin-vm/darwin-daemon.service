[Unit]
Description=Rail Statistics Darwin daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=railstats
Group=railstats
WorkingDirectory=/opt/railstats
EnvironmentFile=/etc/darwin-daemon.env
ExecStart=/usr/bin/npm --prefix darwin-local-test run daemon
Restart=always
RestartSec=5
# Large JSON persist on SIGTERM can exceed 30s; avoid systemd SIGKILL mid-flush.
TimeoutStopSec=180

[Install]
WantedBy=multi-user.target
