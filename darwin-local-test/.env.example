# Copy to .env and fill in. This file is safe to commit (no secrets).
# The real .env in this folder is gitignored.

# ---- Confluent Cloud / Darwin Kafka ----
DARWIN_BOOTSTRAP=pkc-z3p1v0.europe-west2.gcp.confluent.cloud:9092
DARWIN_SASL_MECHANISM=plain
DARWIN_USERNAME=YOUR_CONFLUENT_API_KEY
DARWIN_PASSWORD=YOUR_CONFLUENT_API_SECRET

# Pick ONE topic. The JSON topic is easiest to parse.
#   -JSON  : `bytes` is a JSON string of the Pport object
#   -XML   : `bytes` is base64 of (possibly gzipped) XML
#   -AVRO  : needs Schema Registry credentials (not implemented here)
DARWIN_TOPIC=prod-1010-Darwin-Train-Information-Push-Port-IIII2_0-JSON
# Optional override; auto-detected from the topic name suffix if omitted.
# DARWIN_PAYLOAD_FORMAT=json

# Consumer group from Rail Data Marketplace credentials page
DARWIN_GROUP_ID=SC-7b1e1122-f920-4c79-9235-2c27a16aa7ca

# ---- Test behaviour ----
DARWIN_LEEDS_TIPLOC=LEEDS
DARWIN_LEEDS_CRS=LDS
DARWIN_TEST_DURATION_SEC=120
DARWIN_FROM_BEGINNING=false
# Set to 1 to dump a raw decoded XML sample on first message received
DARWIN_DUMP_FIRST_XML=0
