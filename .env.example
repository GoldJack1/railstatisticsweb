# Copy to .env.local and fill in. Never commit .env.local.

# Firebase (required for Firestore)
VITE_FIREBASE_API_KEY=
# Auth domain: default PROJECT_ID.firebaseapp.com, or custom e.g. auth.railstatistics.co.uk (see docs/SETUP_GOOGLE_APPLE_SIGNIN.md)
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase App Check (reCAPTCHA v3 site key). Secret key goes in Firebase Console only.
# Register the web app in Firebase Console → App Check, then paste the *site* key here for production.
VITE_FIREBASE_APP_CHECK_RECAPTCHA_SITE_KEY=
# Set to true to disable client App Check (debug only). If Auth App Check enforcement is ON in Firebase,
# use Monitoring or fix the site key instead.
# VITE_FIREBASE_APP_CHECK_DISABLED=true

# Optional: same-origin map proxies (needs `netlify dev` or production deploy). Set in netlify.toml for Netlify builds.
# VITE_USE_OSM_PROXY=true

# Optional
# VITE_USE_FIREBASE_EMULATOR=true
# VITE_USE_LOCAL_DATA_ONLY=true
# Note: local dev no longer falls back to JSON automatically. `VITE_USE_LOCAL_DATA_ONLY=true`
# is now the explicit opt-in switch to use `public/data/*.json` instead of Firebase.
# Optional: real Firebase Email/Password for local dev (put in .env.local only — never commit).
# Runs on app load so you skip manual login. Enable Email/Password in Firebase Console.
# VITE_LOCAL_AUTH_EMAIL=you@example.com
# VITE_LOCAL_AUTH_PASSWORD=your-password

# Email allowed to publish pending changes & server schedules (default: wingatejack2021@gmail.com).
# Firestore write access is enforced in firestore.rules — changing this alone does not grant server-side access.
# See docs/SECURITY_FIRESTORE.md and npm run firebase:set-station-editor-claim
# VITE_MASTER_PUBLISH_EMAIL=you@example.com

# Publish now / Save server schedule always require password + authenticator (TOTP) in the modal.
# Env vars below are only for other/future sensitive flows.
# VITE_REQUIRE_REAUTH_FOR_SENSITIVE_ACTIONS=true
# VITE_REQUIRE_SMS_FOR_SENSITIVE_ACTIONS=true
