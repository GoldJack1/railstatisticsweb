rules_version = '2';

/**
 * Firestore security
 * ------------------
 * - All documents: **public read** (no sign-in required), including station collections and scheduled jobs.
 * - Writes: station editors for stations; scheduled jobs: create, delete own, and limited update (pending → cancelled only); other paths no client writes.
 *
 * Who is a "station editor"?
 * - Custom claim `rs_station_editor == true` (set via scripts/set-rs-station-editor-claim.mjs), OR
 * - Sign-in email matches DEFAULT_OWNER_EMAIL below (keep in sync with
 *   src/utils/masterPublishPolicy.ts DEFAULT_MASTER_PUBLISH_EMAIL when you change the default owner).
 *
 * VITE_MASTER_PUBLISH_EMAIL in the web app does NOT change these rules — deploy updated rules or use the claim.
 *
 * Writes to paths without an explicit allow are denied (see catch-all at end).
 */
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    /** Must match masterPublishPolicy DEFAULT_MASTER_PUBLISH_EMAIL unless you rely on custom claims only. */
    function defaultOwnerEmail() {
      return 'wingatejack2021@gmail.com';
    }

    function isStationEditor() {
      return isSignedIn() && (
        request.auth.token.rs_station_editor == true ||
        (
          request.auth.token.email is string
          && request.auth.token.email.lower().trim() == defaultOwnerEmail().lower().trim()
        )
      );
    }

    /**
     * Client cancel update: pending → cancelled via merge update.
     * Use added/changed/removed key sets (not affectedKeys().hasOnly) so we do not reject valid
     * writes when Firestore classifies the same logical change across those sets differently.
     */
    function scheduleJobCancelDiffOk() {
      let d = request.resource.data.diff(resource.data);
      return d.removedKeys().size() == 0
        && d.changedKeys().hasOnly(['status'])
        && (
          d.addedKeys().hasOnly(['cancelledAt'])
          || d.addedKeys().hasOnly(['cancelledAt', 'cancelReason'])
          || d.addedKeys().hasOnly(['cancelledAt', 'cancelReason', 'supersededByJobId'])
        );
    }

    match /stations2603/{stationId} {
      allow read: if true;
      allow create, update, delete: if isStationEditor();
    }

    match /newsandboxstations1/{stationId} {
      allow read: if true;
      allow create, update, delete: if isStationEditor();
    }

    match /scheduledStationPublishJobs/{jobId} {
      // Public read: anyone with a document ID can read job payload (pending changes). Restrict here if needed.
      allow read: if true;

      allow create: if isStationEditor()
        && request.resource.data.status == 'pending'
        && request.resource.data.collectionId in ['stations2603', 'newsandboxstations1']
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.stationIds is list
        && request.resource.data.stationIds.size() > 0
        && request.resource.data.stationIds.size() <= 500
        && request.resource.data.changes is map
        && request.resource.data.changes.size() > 0
        && request.resource.data.changes.size() <= 500;

      // Cloud Function updates use Admin SDK (bypasses rules). Clients may only mark their own **pending** job cancelled.
      // Note: do not use `cancelledAt is timestamp` — FieldValue.serverTimestamp() is not a timestamp during rule evaluation.
      // Optional cancelReason + supersededByJobId when a schedule was replaced by merging into a new job.
      allow update: if isStationEditor()
        && resource.data.createdByUid == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status == 'cancelled'
        && request.resource.data.createdByUid == resource.data.createdByUid
        && scheduleJobCancelDiffOk()
        && (!request.resource.data.keys().hasAny(['cancelReason'])
            || (request.resource.data.cancelReason is string
                && request.resource.data.cancelReason in ['user', 'publish', 'superseded']))
        && (!request.resource.data.keys().hasAny(['supersededByJobId'])
            || (request.resource.data.cancelReason == 'superseded'
                && request.resource.data.supersededByJobId is string
                && request.resource.data.supersededByJobId.size() > 0
                && request.resource.data.supersededByJobId.size() <= 800))
        && (request.resource.data.cancelReason != 'superseded'
            || request.resource.data.keys().hasAny(['supersededByJobId']));

      allow delete: if isStationEditor()
        && resource.data.createdByUid == request.auth.uid;
    }

    match /inAppMessages/{messageId} {
      allow read, create, update, delete: if isSignedIn();
    }

    // Every other collection/subcollection: public read; no client writes unless you add a match above.
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
