rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // ✅ FIX: Extend the expiration date to a future time (e.g., Dec 31, 2026)
      allow read: if request.time < timestamp.date(2026, 12, 31);

      // Only signed-in users can write (site can push when users are logged in)
      allow write: if request.auth != null;
    }
  }
}
